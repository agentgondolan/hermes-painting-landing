# Server-only MGEeveryday API credentials. Never prefix these with NEXT_PUBLIC_.
MGEVERYDAY_BASE_URL=https://www.mgeveryday.sg
MGEVERYDAY_API_TOKEN=replace-with-mge-sk-token
MGEVERYDAY_BRAND_ID=116

# Browser-visible BFF base URL. Use same-origin for Cloudflare Pages Functions, or leave empty for local/mock fallback.
NEXT_PUBLIC_MGE_BFF_BASE_URL=same-origin

# Optional browser analytics. For self-hosted PostHog, use the public ingestion host, e.g. https://posthog.example.com.
# The project token starts with phc_ and is safe to expose in the browser; never put a personal API key here.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
# Optional build/version label attached to analytics events.
NEXT_PUBLIC_APP_VERSION=
